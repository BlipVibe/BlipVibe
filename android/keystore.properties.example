# Release signing config for the Android app.
#
# To enable release signing for Google Play upload:
#   1. Generate an upload keystore (one-time, store the keystore + this
#      file somewhere safe — losing them locks you out of Play updates):
#
#        keytool -genkey -v \
#          -keystore android/app/blipvibe-upload.jks \
#          -alias blipvibe-upload \
#          -keyalg RSA -keysize 2048 -validity 10000
#
#   2. Copy this file to android/keystore.properties (no .example suffix)
#      and fill in the values below.
#   3. The android/ directory is the Gradle root, so storeFile is resolved
#      relative to android/. With the keytool command above, use:
#        storeFile=app/blipvibe-upload.jks
#
# Both keystore.properties and *.jks are gitignored — never commit them.

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=blipvibe-upload
storeFile=app/blipvibe-upload.jks
